+    fn build_azure_ws_url(
+        parsed: &url::Url,
+        host: &str,
+        model: Option<&str>,
+    ) -> (url::Url, Vec<(String, String)>) {
+        let existing_params = super::extract_query_params(parsed);
+
+        let deployment = model
+            .or_else(|| {
+                existing_params
+                    .iter()
+                    .find(|(k, _)| k == "deployment")
