    </span>
    <span class="relative inline-flex overflow-hidden">
      <span class="cycling-text active" data-index="0">Claude Code</span>
      <span class="cycling-text" data-index="2">Codex</span>
      <span class="cycling-text" data-index="4">OpenClaw</span>
    </span>
    <span>.</span>
  </span>
</p>

<style>
  .cycling-icon.active {
    opacity: 1;
  }

  .cycling-text {
    position: absolute;
    white-space: nowrap;
    font-weight: 500;
    color: var(--color-neutral-400);
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .cycling-text.active {
    position: relative;
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const CYCLE_INTERVAL = 3000;
  const SEQUENCE = [0, 2, 4];

  let pos = 0;

  function getByIndex(selector: string, idx: number) {
    return document.querySelector<HTMLElement>(`${selector}[data-index="${idx}"]`);
  }

  setInterval(() => {
    const cur = SEQUENCE[pos];
    getByIndex(".cycling-icon", cur)?.classList.remove("active");
    getByIndex(".cycling-text", cur)?.classList.remove("active");

    pos = (pos + 1) % SEQUENCE.length;

    const next = SEQUENCE[pos];
    getByIndex(".cycling-icon", next)?.classList.add("active");
    getByIndex(".cycling-text", next)?.classList.add("active");
  }, CYCLE_INTERVAL);
</script>
